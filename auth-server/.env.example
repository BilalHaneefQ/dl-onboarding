# Omnio OAuth Server — required environment variables
# Copy to .env and fill in values before starting the server.

# ─── Server ──────────────────────────────────────────────────────────────────

# Public hostname (without protocol) for the OAuth redirect URI.
# Local dev: localhost:8080
# Production VPS: your-vps-domain.com  (must match a redirect URI in Google Cloud Console)
OAUTH_HOST=localhost:8080

# Port for the auth server (default: 8080)
# Must NOT conflict with OpenClaw gateway port (18789)
OAUTH_PORT=8080

# ─── Google OAuth ────────────────────────────────────────────────────────────

# gog OAuth client name (set during: gog auth credentials set --name omnio /path/to/client_secret.json)
# The client_secret.json must be a "Desktop app" type (not "Web Application") — see LEARNINGS.md §11
GOG_CLIENT=omnio

# gog keyring backend — always use file on headless Linux — see LEARNINGS.md §12
GOG_KEYRING_BACKEND=file
GOG_KEYRING_PASSWORD=change-me-in-production

# ─── Discord ─────────────────────────────────────────────────────────────────

# Discord bot token — same token used by the OpenClaw gateway
# From: Discord Developer Portal → Your App → Bot → Reset Token
DISCORD_BOT_TOKEN=

# ─── Setup checklist ─────────────────────────────────────────────────────────
# Before starting the server:
# 1. Add `https://{OAUTH_HOST}/oauth2/callback` to your Google Cloud OAuth client's
#    Authorized redirect URIs (Google Cloud Console → APIs & Services → Credentials)
# 2. Run: gog auth credentials set --name omnio /path/to/client_secret.json
# 3. Start the gateway: openclaw-start alias (see LEARNINGS.md §20)
# 4. Start the auth server: OAUTH_HOST=your-vps-domain.com node server.js
